# PostgreSQL
POSTGRES_DB=ticketalert
POSTGRES_USER=ticketalert
POSTGRES_PASSWORD=change_me_to_a_secure_password

# Backend connection string (uses the service name from docker-compose)
ConnectionStrings__DefaultConnection=Host=postgres;Database=ticketalert;Username=ticketalert;Password=change_me_to_a_secure_password

# JWT
Jwt__Key=super-secret-key-at-least-32-characters-long-for-hmac-sha256
Jwt__Issuer=TicketAlert
Jwt__Audience=TicketAlert

# Ticketmaster
Ticketmaster__ApiKey=tm_your_api_key_here

# Stripe
Stripe__SecretKey=sk_test_your_stripe_secret_key
Stripe__WebhookSecret=whsec_your_webhook_secret

# Email (SMTP / SendGrid)
Email__FromAddress=noreply@ticketalert.no
Email__SmtpHost=smtp.sendgrid.net
Email__SmtpPort=587
Email__Username=apikey
Email__Password=your_sendgrid_api_key

# Pricing
Pricing__PerWatchNok=19

# CORS (frontend URL for Coolify)
Cors__Origins=http://localhost:5173

# ASP.NET
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
